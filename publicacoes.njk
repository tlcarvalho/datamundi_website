---
layout: base.njk
nav_key: publicacoes
titulo_pagina: Publicações
permalink: /publicacoes/
kicker: Produção científica
titulo: Publicações
filtros:
  - Todos
  - Artigo
  - Relatório
  - Livro
---
<div class="page">
  <div class="wrap">
    <div class="kicker reveal in">{{ kicker }}</div>
    <h1 class="h1">{{ titulo }}</h1>
    <div class="filtros" data-filtro-grupo="#lista-publicacoes">
      {% for f in filtros %}
        <button class="filtro{% if loop.first %} on{% endif %}" data-valor="{{ f }}">{{ f }}</button>
      {% endfor %}
    </div>
    <div id="lista-publicacoes">
      {# Relatórios — hospedados no site, cada um com página própria #}
      {% for r in collections.relatorio | reverse %}
        <a class="reveal pubrow" href="{{ r.url }}" data-tag="Relatório" style="transition-delay: {{ loop.index0 * 60 }}ms">
          <span class="pub-tipo">Relatório</span>
          <div class="pub-body">
            <h3>{{ r.data.titulo }}</h3>
            <div class="pub-meta">{{ r.data.autores }}{% if r.data.ano %} · {{ r.data.ano }}{% endif %}</div>
          </div>
          <span class="pub-doi">Abrir →</span>
        </a>
      {% endfor %}
      {# Artigos, livros etc. — link externo via DOI #}
      {% for p in publicacoes.lista %}
        {% if p.doi %}
          <a class="reveal pubrow" href="https://doi.org/{{ p.doi | trim }}" target="_blank" rel="noopener" data-tag="{{ p.tipo }}" style="transition-delay: {{ loop.index0 * 60 }}ms">
            <span class="pub-tipo">{{ p.tipo }}</span>
            <div class="pub-body">
              <h3>{{ p.titulo }}</h3>
              <div class="pub-meta">{{ p.autores }} · <em>{{ p.revista }}</em> · {{ p.ano }}</div>
            </div>
            <span class="pub-doi">DOI →</span>
          </a>
        {% else %}
          <div class="reveal pubrow" data-tag="{{ p.tipo }}" style="transition-delay: {{ loop.index0 * 60 }}ms">
            <span class="pub-tipo">{{ p.tipo }}</span>
            <div class="pub-body">
              <h3>{{ p.titulo }}</h3>
              <div class="pub-meta">{{ p.autores }} · <em>{{ p.revista }}</em> · {{ p.ano }}</div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
