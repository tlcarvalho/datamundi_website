---
layout: base.njk
nav_key: boletim
---
<article class="page">
  <div class="wrap artigo-wrap">
    <a class="artigo-voltar" href="/boletim/">← Voltar ao Boletim</a>
    <div class="mono-date" style="margin-bottom: 18px">{{ date | dataBR }}{% if autor %} · por {{ autor }}{% endif %}</div>
    <h1 class="h1" style="margin-bottom: 24px">{{ titulo }}</h1>
    {% if resumo %}<p class="lead" style="margin-bottom: 36px">{{ resumo }}</p>{% endif %}
    {% if imagem %}<img class="artigo-hero" src="{{ imagem }}" alt="{{ titulo }}" />{% endif %}
    <div class="artigo">{{ content | safe }}</div>
  </div>
</article>
